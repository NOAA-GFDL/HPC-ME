ARG CUDA_VERSION=13.0
ARG NVHPC_VERSION=25.11
ARG ROCKY_VERSION=9

# Build stage with Spack and NVHPC
FROM nvcr.io/nvidia/nvhpc:${NVHPC_VERSION}-devel-cuda${CUDA_VERSION}-rockylinux${ROCKY_VERSION} as builder

# Install yum-utils to get `yum-config-manager`
# Enable `crb` to access blas-devel and lapac-devel
RUN yum install -y yum-utils && \
    yum-config-manager --enable crb

# Install core build dependencies
RUN yum install -y \
        patch \
        xz \
        file \
        bzip2-devel \
        glibc-devel \
        libcurl-devel \
        libedit-devel \
        libffi-devel \
        gmp-devel \
        libmpc-devel \
        mpfr-devel \
        ncurses-devel \
        readline-devel \
        openssl-devel \
        zlib-devel \
        blas-devel \
        lapack-devel \
        pkgconfig \
        python3 \
        python3-devel \
        unzip && \
    yum clean all && \
    rm -rf /var/cache/yum/*

# Install Spack v1.1.0
RUN git clone -c feature.manyObjectsThreshold=false -b v1.1.0 https://github.com/spack/spack.git /opt/spack

# Initialize Spack environment
RUN mkdir -p /opt/spack-environment && \
    cd /opt/spack-environment && \
    . /opt/spack/share/spack/setup-env.sh && \
    spack env create --dir .

# Configure externals for NVIDIA NVHPC compilers and libraries
RUN cd /opt/spack-environment && \
    . /opt/spack/share/spack/setup-env.sh && \
    spack env activate . && \
    spack external find --all --scope=site cmake git wget ca-certificates python ncurses readline zlib bzip2 openssl libedit libffi

# Configure Spack environment
RUN cd /opt/spack-environment && \
    . /opt/spack/share/spack/setup-env.sh && \
    spack env activate .

# Add packages with nvhpc compiler
RUN cd /opt/spack-environment && \
    . /opt/spack/share/spack/setup-env.sh && \
    spack env activate . && \
    spack add 'gmake %gcc' && \
    spack add 'zlib %gcc' && \
    spack add 'zlib-ng %gcc' && \
    spack add 'libyaml %nvhpc@25.11' && \
    spack add 'bacio %nvhpc@25.11' && \
    spack add 'hdf5 +fortran +hl +szip ~mpi %nvhpc@25.11' && \
    spack add 'nccmp %nvhpc@25.11' && \
    spack add 'netcdf-c ~mpi %nvhpc@25.11' && \
    spack add 'netcdf-fortran %nvhpc@25.11' && \
    spack add 'sp %nvhpc@25.11' && \
    spack add 'w3emc %nvhpc@25.11' && \
    spack add 'w3nco %nvhpc@25.11'

# Discover compiler and concretize dependencies
RUN cd /opt/spack-environment && \
    . /opt/spack/share/spack/setup-env.sh && \
    spack env activate . && \
    spack compiler find && \
    spack compiler add /opt/nvidia/hpc_sdk/Linux_x86_64/25.11/compilers && \
    spack concretize -f

# Install all packages
RUN cd /opt/spack-environment && \
    . /opt/spack/share/spack/setup-env.sh && \
    spack env activate . && \
    spack install --fail-fast -j 4 && \
    spack gc -y || \
    (mkdir -p /opt/build-logs && \
     find /tmp -name "spack-build-out.txt" -o -name "config.log" | xargs -I {} cp {} /opt/build-logs/ 2>/dev/null; \
     exit 1)

# Set environment variables for runtime
RUN echo "source /opt/spack-environment/.spack-env/view/etc/profile.d/z10_spack_environment.sh" >> /opt/spack-setup.sh
ENV LD_LIBRARY_PATH=/opt/spack-environment/.spack-env/view/lib:/opt/spack-environment/.spack-env/view/lib64:$LD_LIBRARY_PATH \
    LIBRARY_PATH=/opt/spack-environment/.spack-env/view/lib:/opt/spack-environment/.spack-env/view/lib64:$LIBRARY_PATH \
    PATH=/opt/spack-environment/.spack-env/view/bin:$PATH

# Final runtime stage - lightweight image
FROM nvcr.io/nvidia/nvhpc:${NVHPC_VERSION}-runtime-cuda${CUDA_VERSION}-rockylinux${ROCKY_VERSION}

# Install minimal runtime dependencies
RUN yum install -y \
        ca-certificates \
        libgomp && \
    yum clean all && \
    rm -rf /var/cache/yum/*

# Copy spack environment from builder
COPY --from=builder /opt/spack-environment /opt/spack-environment

# Set environment variables
ENV LD_LIBRARY_PATH=/opt/spack-environment/.spack-env/view/lib:/opt/spack-environment/.spack-env/view/lib64:$LD_LIBRARY_PATH \
    LIBRARY_PATH=/opt/spack-environment/.spack-env/view/lib:/opt/spack-environment/.spack-env/view/lib64:$LIBRARY_PATH \
    PATH=/opt/spack-environment/.spack-env/view/bin:$PATH

WORKDIR /opt/work
ENTRYPOINT ["/bin/bash"]
